---
import BunzoLayout from '../layouts/BunzoLayout.astro';
import Breadcrumb from '../components/bunzo/Breadcrumb.astro';
import NewsletterTwo from '../components/bunzo/NewsletterTwo.astro';
import { readData } from '../lib/readData';

const aboutData = readData('about.json');
---

<BunzoLayout title={`${aboutData.title} - Bunzo`}>
    <div class="about-wrapper">
        <Breadcrumb slug={aboutData.title} />

        <div class="py-section container mx-auto px-4">
            <div class="grid lg:grid-cols-2 gap-10 items-center">
                <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
                    <img src={aboutData.intro.image} alt={aboutData.intro.title} class="w-full h-[400px] object-cover transition-transform duration-700 group-hover:scale-105">
                </div>
                <div class="content">
                    <h2 class="text-4xl font-bold font-heading text-primary mb-6">{aboutData.intro.title}</h2>
                    <p class="text-lg text-gray-600 mb-6 leading-relaxed">{aboutData.intro.description}</p>
                    <ul class="space-y-4 font-medium text-heading">
                        {aboutData.intro.features.map((feature: string) => (
                            <li class="flex items-center"><i class="icofont-check-circled text-primary mr-3 text-xl"></i> {feature}</li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>

        <div class="py-section bg-gray-50">
            <div class="container mx-auto px-4">
                <div class="grid md:grid-cols-2 gap-10">
                    <div class="bg-white p-10 rounded-2xl shadow-sm border-t-4" style={`border-top-color: var(--color-primary);`}>
                        <h3 class="text-2xl font-bold font-heading mb-4" style={`color: var(--color-primary);`}>{aboutData.mission.title}</h3>
                        <p class="text-gray-600 leading-relaxed">{aboutData.mission.description}</p>
                    </div>
                    <div class="bg-white p-10 rounded-2xl shadow-sm border-t-4" style={`border-top-color: var(--color-accent);`}>
                        <h3 class="text-2xl font-bold font-heading mb-4" style={`color: var(--color-accent);`}>{aboutData.vision.title}</h3>
                        <p class="text-gray-600 leading-relaxed">{aboutData.vision.description}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="py-section bg-[#edf0f8]">
            <div class="container mx-auto px-4">
                <NewsletterTwo />
            </div>
        </div>
    </div>
</BunzoLayout>
