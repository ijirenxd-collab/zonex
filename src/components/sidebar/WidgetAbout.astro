---
import { readData } from '../../lib/readData';
import SocialIcon from '../bunzo/SocialIcon.astro';

const siteConfig = readData('siteConfig.json');
const social = siteConfig.social || {};
---

<div class="sidebar-widget mb-10 text-center border border-gray-100 rounded-[10px] p-8 bg-white">
  <div class="footer-logo mb-6">
    <a href="/">
      {siteConfig.logo ? (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 mx-auto">
      ) : (
        <span class="text-xl font-bold font-heading text-heading">{siteConfig.name}</span>
      )}
    </a>
  </div>
  
  <p class="text-gray-500 text-sm mb-8 leading-relaxed">
    {siteConfig.description}
  </p>

  <div class="flex justify-center space-x-3">
    {social.facebook && <SocialIcon icon="icofont-facebook" url={social.facebook} styleClass="w-9 h-9 leading-9 rounded-full bg-gray-50 hover:bg-primary hover:text-white" />}
    {social.twitter && <SocialIcon icon="icofont-twitter" url={social.twitter} styleClass="w-9 h-9 leading-9 rounded-full bg-gray-50 hover:bg-primary hover:text-white" />}
    {social.instagram && <SocialIcon icon="icofont-instagram" url={social.instagram} styleClass="w-9 h-9 leading-9 rounded-full bg-gray-50 hover:bg-primary hover:text-white" />}
  </div>
</div>
