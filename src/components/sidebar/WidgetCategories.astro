---
import WidgetTitle from './WidgetTitle.astro';

interface CategoryCount {
  name: string;
  count: number;
}

interface Props {
  categories: CategoryCount[];
}

const { categories } = Astro.props;
---

<div class="sidebar-widget mb-10">
  <WidgetTitle title="Categorias" />
  
  <ul class="category-list space-y-3">
    {categories.map(cat => (
      <li>
        <a 
          href={`/categoria/${cat.name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} 
          class="flex justify-between items-center py-2 px-4 bg-gray-50 rounded-lg hover:bg-primary hover:text-white transition-all group"
        >
          <span class="font-bold text-gray-700 group-hover:text-white capitalize transition-colors">{cat.name}</span>
          <span class="text-xs bg-white text-gray-400 px-2.5 py-1 rounded-md font-bold group-hover:bg-white group-hover:text-primary transition-all">
            {cat.count}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
