---
// Componente OffcanvasSearchBox.astro
---
<div id="offcanvas-search" class="fixed top-0 left-0 w-screen h-screen opacity-0 invisible z-50 transition-all duration-300">
    <div class="top-0 left-0 w-full h-full absolute bg-black bg-opacity-80 search-overlay"></div>
    <div class="mobile-search-inner p-5 relative w-full h-40 text-left bg-white -translate-y-full transition-all duration-500">
        <button id="close-search" class="absolute top-24 left-1/2 -translate-x-1/2 text-4xl hover:text-primary group">
            <i class="icofont-close-line group-hover:rotate-180 block transition-all duration-500"></i>
        </button>
        <div class="search-box relative max-w-4xl mx-auto pt-10">
            <input type="text" id="search-input" placeholder="Escreva sua busca..." class="text-heading-light border-1 rounded-md pl-3 pr-15 py-3 w-full focus:border-primary focus:outline-none">
            <button aria-label="Search" id="exec-search" class="w-12 h-full absolute right-0 top-1/2 transform -translate-y-1/2 text-white bg-primary text-xl rounded-tr-md rounded-br-md">
                <i class="icofont-search"></i>
            </button>
        </div>
    </div>
</div>

<style lang="scss">
    .show-search-box {
        opacity: 1 !important;
        visibility: visible !important;
    }
    .show-search-box .mobile-search-inner {
        transform: none !important;
    }
</style>

<script>
    const searchBox = document.getElementById('offcanvas-search');
    const closeBtn = document.getElementById('close-search');
    const overlay = document.querySelector('.search-overlay');
    const execBtn = document.getElementById('exec-search');
    const input = document.getElementById('search-input') as HTMLInputElement;

    function toggleSearch() {
        searchBox?.classList.toggle('show-search-box');
    }

    closeBtn?.addEventListener('click', toggleSearch);
    overlay?.addEventListener('click', toggleSearch);

    execBtn?.addEventListener('click', () => {
        if (input?.value) {
            window.location.href = `/search/${input.value}`;
        }
    });

    input?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && input.value) {
            window.location.href = `/search/${input.value}`;
        }
    });

    // Escutar evento global para abrir busca
    window.addEventListener('openSearch', toggleSearch);
</script>
