---
import { readData } from '../../lib/readData';

const homeData = readData('home.json');
const partnersLogo = homeData.partners || [];
---
<div class="trusted-partner py-section mt-10">
    <div class="container mx-auto px-4">
        <div class="bg-[#f4eaff] py-16 px-10 lg:px-20 rounded-2xl shadow-inner">
            <div class="swiper-container partner-slider overflow-hidden">
                <div class="swiper-wrapper flex items-center">
                    {partnersLogo.map((logo) => (
                        <div class="swiper-slide opacity-60 hover:opacity-100 transition-opacity flex justify-center">
                            <img src={logo} alt="logo" class="grayscale hover:grayscale-0 transition-all max-h-12">
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    import Swiper from 'swiper';
    import { Autoplay } from 'swiper/modules';
    import 'swiper/css';

    new Swiper('.partner-slider', {
        modules: [Autoplay],
        speed: 1000,
        loop: true,
        autoplay: {
            delay: 3000,
            disableOnInteraction: false,
        },
        slidesPerView: 2,
        spaceBetween: 30,
        breakpoints: {
            992: { slidesPerView: 4, spaceBetween: 70 },
            768: { slidesPerView: 3, spaceBetween: 50 },
        }
    });
</script>
