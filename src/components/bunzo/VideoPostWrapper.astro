---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
import PostStyleTwo from './PostStyleTwo.astro';

const homeConfig = readData('home.json');
const videoSectionConfig = homeConfig.videoSection || {};

const allPosts = await getCollection('blog');
const videoPosts = allPosts.slice(0, videoSectionConfig.limit || 2);
---

<div class="video-post-wrapper py-section bg-white">
  <div class="container mx-auto px-4">
    <div class="section-title mb-12 flex justify-between items-center border-b border-gray-100 pb-5">
      <h2 class="text-2xl font-bold mb-0 leading-6 font-heading text-heading">
        {videoSectionConfig.title || "Vídeos em Destaque"}
      </h2>
      <a href="/blog" class="text-base font-bold text-heading hover:text-primary transition-colors flex items-center">
        Ver Mais <i class="icofont-long-arrow-right ml-2 text-xl"></i>
      </a>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {videoPosts.map(post => (
        <PostStyleTwo post={post} textVariant="lg:text-2xl font-bold" />
      ))}
    </div>
  </div>
</div>
